SHELL      := bash
.SHELLFLAGS := -o pipefail -c

# -------------------------------------------------------------------------
# sdram_test_02 -- SDRAM read path timing laboratory (sim only)
# Target: diagnose 16-bit -> 32-bit word assembly at 125 MHz / CL=3 / BL=1
# No Quartus. No HW. No AXI.
# -------------------------------------------------------------------------

.PHONY: clean gen-cfg test-assembler test-phy-single test-phy-back2back \
        test-word32 sweep-rshift help

RSHIFT  ?= 0
CMDREG  := 1
PROJECT := sdram_test_02

# RSHIFT label for log filenames: -1->m1, 0->0, 1->p1
rshift_label = $(if $(filter -1,$(RSHIFT)),m1,$(if $(filter 1,$(RSHIFT)),p1,$(RSHIFT)))

RTL    := rtl/sdram
MODEL  := sim/model
TB     := sim/tb
LOGDIR := sim/logs

VLOG := vlog -sv -suppress 2892 +define+SIM +incdir+$(RTL)
VSIM := vsim -c -do "run -all; quit"

# -------------------------------------------------------------------------
# Build config generation (updates sdram_build_cfg.svh)
# -------------------------------------------------------------------------
gen-cfg:
	@echo "# gen-cfg: PROJECT=$(PROJECT) RSHIFT=$(RSHIFT) CMDREG=$(CMDREG)"
	@printf '// sdram_build_cfg.svh -- GENERATED by Makefile gen-cfg. DO NOT EDIT.\n' \
	  > $(RTL)/sdram_build_cfg.svh
	@printf '// RSHIFT=$(RSHIFT)  CMDREG=$(CMDREG)\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`ifndef SDRAM_BUILD_CFG_SVH\n`define SDRAM_BUILD_CFG_SVH\n\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`define SDRAM_BUILD_READ_CAPTURE_SHIFT $(RSHIFT)\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`define SDRAM_BUILD_CMD_REG_ON_CLK_SH  $(CMDREG)\n\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`endif // SDRAM_BUILD_CFG_SVH\n' \
	  >> $(RTL)/sdram_build_cfg.svh

# -------------------------------------------------------------------------
# Log header helper
# -------------------------------------------------------------------------
define write_log_header
	@mkdir -p $(LOGDIR)
	@echo "# BUILD_CONFIG PROJECT=$(PROJECT) RSHIFT=$(RSHIFT) CMDREG=$(CMDREG)" \
	  > $(LOGDIR)/$(1).log
endef

# -------------------------------------------------------------------------
# Test 1: pure assembler unit test (no SDRAM, no PHY)
# -------------------------------------------------------------------------
test-assembler: gen-cfg
	$(VLOG) \
	  $(RTL)/read_word_assembler.sv \
	  $(TB)/tb_read_word_assembler.sv
	$(call write_log_header,tb_read_word_assembler)
	$(VSIM) tb_read_word_assembler 2>&1 | tee -a $(LOGDIR)/tb_read_word_assembler.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_read_word_assembler.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# Test 2: PHY single 16-bit read
# Log name is unique per RSHIFT: tb_phy_single_read_rshift_<label>.log
# -------------------------------------------------------------------------
test-phy-single: gen-cfg
	$(VLOG) \
	  $(RTL)/sdram_pkg.sv \
	  $(RTL)/sdram_phy.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_phy_single_read.sv
	$(call write_log_header,tb_phy_single_read_rshift_$(rshift_label))
	$(VSIM) tb_phy_single_read 2>&1 | tee -a $(LOGDIR)/tb_phy_single_read_rshift_$(rshift_label).log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_phy_single_read_rshift_$(rshift_label).log; then \
	  echo "  PASS (RSHIFT=$(RSHIFT), log=tb_phy_single_read_rshift_$(rshift_label).log)"; \
	else \
	  echo "  FAIL (RSHIFT=$(RSHIFT), log=tb_phy_single_read_rshift_$(rshift_label).log)"; exit 1; \
	fi

# -------------------------------------------------------------------------
# Test 3: PHY back-to-back reads
# -------------------------------------------------------------------------
test-phy-back2back: gen-cfg
	$(VLOG) \
	  $(RTL)/sdram_pkg.sv \
	  $(RTL)/sdram_phy.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_phy_back_to_back_reads.sv
	$(call write_log_header,tb_phy_back_to_back_reads)
	$(VSIM) tb_phy_back_to_back_reads 2>&1 | tee -a $(LOGDIR)/tb_phy_back_to_back_reads.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_phy_back_to_back_reads.log; then \
	  echo "  PASS (RSHIFT=$(RSHIFT))"; \
	else \
	  echo "  FAIL (RSHIFT=$(RSHIFT))"; exit 1; \
	fi

# -------------------------------------------------------------------------
# Test 4: full 32-bit word timing (PHY + assembler)
# -------------------------------------------------------------------------
test-word32: gen-cfg
	$(VLOG) \
	  $(RTL)/sdram_pkg.sv \
	  $(RTL)/sdram_phy.sv \
	  $(RTL)/read_word_assembler.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_read_32bit_word_timing.sv
	$(call write_log_header,tb_read_32bit_word_timing)
	$(VSIM) tb_read_32bit_word_timing 2>&1 | tee -a $(LOGDIR)/tb_read_32bit_word_timing.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_read_32bit_word_timing.log; then \
	  echo "  PASS (RSHIFT=$(RSHIFT))"; \
	else \
	  echo "  FAIL (RSHIFT=$(RSHIFT))"; exit 1; \
	fi

# -------------------------------------------------------------------------
# Sweep RSHIFT = -1, 0, +1 (PHY single read)
# Each RSHIFT writes to its own log. Final exit 1 if any point failed.
# -------------------------------------------------------------------------
sweep-rshift:
	@echo "=== sweep-rshift: RSHIFT=-1, 0, +1 ==="
	-$(MAKE) test-phy-single RSHIFT=-1
	-$(MAKE) test-phy-single RSHIFT=0
	-$(MAKE) test-phy-single RSHIFT=1
	@echo ""
	@echo "=== sweep-rshift results ==="
	@SWEEP_FAIL=0; \
	for entry in "-1:m1" "0:0" "1:p1"; do \
	  r=$${entry%%:*}; label=$${entry##*:}; \
	  LOG="$(LOGDIR)/tb_phy_single_read_rshift_$${label}.log"; \
	  if grep -q "\*\*\* PASS \*\*\*" "$$LOG" 2>/dev/null; then \
	    echo "  RSHIFT=$$r: PASS, log=$$LOG"; \
	  else \
	    echo "  RSHIFT=$$r: FAIL, log=$$LOG"; \
	    SWEEP_FAIL=1; \
	  fi; \
	done; \
	echo ""; \
	if [ "$$SWEEP_FAIL" = "1" ]; then \
	  echo "=== sweep-rshift: FAIL (one or more RSHIFT points failed) ==="; \
	  exit 1; \
	else \
	  echo "=== sweep-rshift: PASS (all RSHIFT points passed) ==="; \
	fi

# -------------------------------------------------------------------------
# Clean
# -------------------------------------------------------------------------
clean:
	rm -rf work transcript *.wlf $(LOGDIR)/*.log

# -------------------------------------------------------------------------
# Help
# -------------------------------------------------------------------------
help:
	@echo "sdram_test_02 -- SDRAM read path timing laboratory"
	@echo "==================================================="
	@echo ""
	@echo "Variables:"
	@echo "  RSHIFT=<int>  READ_CAPTURE_SHIFT (default: 0)"
	@echo "  CMDREG=1      CMD_REG_ON_CLK_SH (fixed)"
	@echo ""
	@echo "Targets:"
	@echo "  make gen-cfg [RSHIFT=N]        Regenerate sdram_build_cfg.svh"
	@echo "  make test-assembler            Test 1: pure unit test (no SDRAM)"
	@echo "  make test-phy-single [RSHIFT=N] Test 2: PHY single 16-bit read"
	@echo "  make test-phy-back2back [RSHIFT=N] Test 3: two consecutive reads"
	@echo "  make test-word32 [RSHIFT=N]    Test 4: PHY + assembler = 32-bit word"
	@echo "  make sweep-rshift              Run test-phy-single for RSHIFT=-1,0,+1"
	@echo "  make clean                     Remove work/ and logs"
	@echo ""
	@echo "Log format:"
	@echo "  Every log starts with: # BUILD_CONFIG PROJECT=sdram_test_02 RSHIFT=N CMDREG=1"
