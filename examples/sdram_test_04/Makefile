SHELL      := bash
.SHELLFLAGS := -o pipefail -c

# -------------------------------------------------------------------------
# sdram_test_04 -- AXI adapter over proven native_word_port (sim only)
# Baseline from sdram_test_03: RSHIFT=0, CMDREG=1
# No Quartus. No HW. No AXI files from sdram_test_01 yet.
# -------------------------------------------------------------------------

.PHONY: clean gen-cfg test-axi-unit test-axi-protocol test-axi-native-single test-axi-raw-raw test-axi-multi test-axi-backpressure help

RSHIFT  ?= 0
CMDREG  := 1
PROJECT := sdram_test_04

RTL_AXI := rtl/axi
RTL_NAT := rtl/sdram
MODEL   := sim/model
TB      := sim/tb
LOGDIR  := sim/logs

VLOG := vlog -sv -suppress 2892 +define+SIM +incdir+$(RTL_NAT)
VSIM := vsim -c -do "run -all; quit"

# -------------------------------------------------------------------------
# Build config generation (required for M2+ when PHY is involved)
# -------------------------------------------------------------------------
gen-cfg:
	@echo "# gen-cfg: PROJECT=$(PROJECT) RSHIFT=$(RSHIFT) CMDREG=$(CMDREG)"
	@printf '// sdram_build_cfg.svh -- GENERATED by Makefile gen-cfg. DO NOT EDIT.\n' \
	  > $(RTL_NAT)/sdram_build_cfg.svh
	@printf '// RSHIFT=$(RSHIFT)  CMDREG=$(CMDREG)\n' \
	  >> $(RTL_NAT)/sdram_build_cfg.svh
	@printf '`ifndef SDRAM_BUILD_CFG_SVH\n`define SDRAM_BUILD_CFG_SVH\n\n' \
	  >> $(RTL_NAT)/sdram_build_cfg.svh
	@printf '`define SDRAM_BUILD_READ_CAPTURE_SHIFT $(RSHIFT)\n' \
	  >> $(RTL_NAT)/sdram_build_cfg.svh
	@printf '`define SDRAM_BUILD_CMD_REG_ON_CLK_SH  $(CMDREG)\n\n' \
	  >> $(RTL_NAT)/sdram_build_cfg.svh
	@printf '`endif // SDRAM_BUILD_CFG_SVH\n' \
	  >> $(RTL_NAT)/sdram_build_cfg.svh

define write_log_header
	@mkdir -p $(LOGDIR)
	@echo "# BUILD_CONFIG PROJECT=$(PROJECT) RSHIFT=$(RSHIFT) CMDREG=$(CMDREG)" \
	  > $(LOGDIR)/$(1).log
endef

# -------------------------------------------------------------------------
# M1: AXI native adapter unit test (fake native backend, no PHY/model)
# -------------------------------------------------------------------------
test-axi-unit:
	$(VLOG) \
	  $(RTL_AXI)/axi_native_adapter.sv \
	  $(TB)/tb_axi_native_adapter_unit.sv
	$(call write_log_header,tb_axi_native_adapter_unit)
	$(VSIM) tb_axi_native_adapter_unit 2>&1 | tee -a $(LOGDIR)/tb_axi_native_adapter_unit.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_axi_native_adapter_unit.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# M1b: AXI protocol guard unit test (fake native backend, no PHY/model)
# -------------------------------------------------------------------------
test-axi-protocol:
	$(VLOG) \
	  $(RTL_AXI)/axi_native_adapter.sv \
	  $(TB)/tb_axi_native_adapter_protocol_unit.sv
	$(call write_log_header,tb_axi_native_adapter_protocol_unit)
	$(VSIM) tb_axi_native_adapter_protocol_unit 2>&1 | tee -a $(LOGDIR)/tb_axi_native_adapter_protocol_unit.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_axi_native_adapter_protocol_unit.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# M2: Full integration -- AXI adapter + native_word_port + PHY + SDRAM model
# -------------------------------------------------------------------------
test-axi-native-single: gen-cfg
	$(VLOG) \
	  $(RTL_NAT)/sdram_pkg.sv \
	  $(RTL_NAT)/sdram_phy.sv \
	  $(RTL_NAT)/read_word_assembler.sv \
	  $(RTL_NAT)/native_word_port.sv \
	  $(RTL_AXI)/axi_native_adapter.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_axi_native_single_write_read.sv
	$(call write_log_header,tb_axi_native_single_write_read)
	$(VSIM) tb_axi_native_single_write_read 2>&1 | tee -a $(LOGDIR)/tb_axi_native_single_write_read.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_axi_native_single_write_read.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# M2b: AXI raw read-after-BVALID (no manual NWP wait -- hazard test)
# -------------------------------------------------------------------------
test-axi-raw-raw: gen-cfg
	$(VLOG) \
	  $(RTL_NAT)/sdram_pkg.sv \
	  $(RTL_NAT)/sdram_phy.sv \
	  $(RTL_NAT)/read_word_assembler.sv \
	  $(RTL_NAT)/native_word_port.sv \
	  $(RTL_AXI)/axi_native_adapter.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_axi_native_raw_read_after_bvalid.sv
