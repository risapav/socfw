	$(VSIM) tb_axi_native_raw_read_after_bvalid 2>&1 | tee -a $(LOGDIR)/tb_axi_native_raw_read_after_bvalid.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_axi_native_raw_read_after_bvalid.log; then \
