SHELL      := bash
.SHELLFLAGS := -o pipefail -c

# -------------------------------------------------------------------------
# sdram_test_03 -- native 32-bit SDRAM read/write core integration (sim only)
# Proven baseline from sdram_test_02: RSHIFT=0, CMDREG=1
# No Quartus. No HW. No AXI.
# -------------------------------------------------------------------------

.PHONY: clean gen-cfg test-native-unit test-native-single test-native-multi help

RSHIFT  ?= 0
CMDREG  := 1
PROJECT := sdram_test_03

RTL    := rtl/sdram
MODEL  := sim/model
TB     := sim/tb
LOGDIR := sim/logs

VLOG := vlog -sv -suppress 2892 +define+SIM +incdir+$(RTL)
VSIM := vsim -c -do "run -all; quit"

# -------------------------------------------------------------------------
# Build config generation
# -------------------------------------------------------------------------
gen-cfg:
	@echo "# gen-cfg: PROJECT=$(PROJECT) RSHIFT=$(RSHIFT) CMDREG=$(CMDREG)"
	@printf '// sdram_build_cfg.svh -- GENERATED by Makefile gen-cfg. DO NOT EDIT.\n' \
	  > $(RTL)/sdram_build_cfg.svh
	@printf '// RSHIFT=$(RSHIFT)  CMDREG=$(CMDREG)\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`ifndef SDRAM_BUILD_CFG_SVH\n`define SDRAM_BUILD_CFG_SVH\n\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`define SDRAM_BUILD_READ_CAPTURE_SHIFT $(RSHIFT)\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`define SDRAM_BUILD_CMD_REG_ON_CLK_SH  $(CMDREG)\n\n' \
	  >> $(RTL)/sdram_build_cfg.svh
	@printf '`endif // SDRAM_BUILD_CFG_SVH\n' \
	  >> $(RTL)/sdram_build_cfg.svh

define write_log_header
	@mkdir -p $(LOGDIR)
	@echo "# BUILD_CONFIG PROJECT=$(PROJECT) RSHIFT=$(RSHIFT) CMDREG=$(CMDREG)" \
	  > $(LOGDIR)/$(1).log
endef

# -------------------------------------------------------------------------
# M1: native_word_port unit test (no PHY, no SDRAM model)
# -------------------------------------------------------------------------
test-native-unit: gen-cfg
	$(VLOG) \
	  $(RTL)/read_word_assembler.sv \
	  $(RTL)/native_word_port.sv \
	  $(TB)/tb_native_word_port_unit.sv
	$(call write_log_header,tb_native_word_port_unit)
	$(VSIM) tb_native_word_port_unit 2>&1 | tee -a $(LOGDIR)/tb_native_word_port_unit.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_native_word_port_unit.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# M2: native single write+read through PHY + SDRAM model
# -------------------------------------------------------------------------
test-native-single: gen-cfg
	$(VLOG) \
	  $(RTL)/sdram_pkg.sv \
	  $(RTL)/sdram_phy.sv \
	  $(RTL)/read_word_assembler.sv \
	  $(RTL)/native_word_port.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_native_single_write_read.sv
	$(call write_log_header,tb_native_single_write_read)
	$(VSIM) tb_native_single_write_read 2>&1 | tee -a $(LOGDIR)/tb_native_single_write_read.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_native_single_write_read.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# M3: native multi-address smoke test (3 x 32-bit words at addr 0,2,4)
# -------------------------------------------------------------------------
test-native-multi: gen-cfg
	$(VLOG) \
	  $(RTL)/sdram_pkg.sv \
	  $(RTL)/sdram_phy.sv \
	  $(RTL)/read_word_assembler.sv \
	  $(RTL)/native_word_port.sv \
	  $(MODEL)/sdram_model_pro.sv \
	  $(TB)/tb_native_multi_address_smoke.sv
	$(call write_log_header,tb_native_multi_address_smoke)
	$(VSIM) tb_native_multi_address_smoke 2>&1 | tee -a $(LOGDIR)/tb_native_multi_address_smoke.log
	@echo ""
	@echo "RESULT:"
	@if grep -q "\*\*\* PASS \*\*\*" $(LOGDIR)/tb_native_multi_address_smoke.log; then \
	  echo "  PASS"; \
	else \
	  echo "  FAIL"; exit 1; \
	fi

# -------------------------------------------------------------------------
# Clean
# -------------------------------------------------------------------------
clean:
	rm -rf work transcript *.wlf $(LOGDIR)/*.log

# -------------------------------------------------------------------------
# Help
# -------------------------------------------------------------------------
help:
	@echo "sdram_test_03 -- native 32-bit SDRAM read/write core integration"
	@echo "================================================================="
	@echo ""
	@echo "Variables:"
	@echo "  RSHIFT=0   READ_CAPTURE_SHIFT (fixed from sdram_test_02)"
	@echo "  CMDREG=1   CMD_REG_ON_CLK_SH (fixed)"
	@echo ""
	@echo "Targets:"
	@echo "  make gen-cfg              Regenerate sdram_build_cfg.svh"
	@echo "  make test-native-unit     M1: native_word_port unit (no PHY)"
	@echo "  make test-native-single   M2: single write+read (PHY + model)"
	@echo "  make test-native-multi    M3: multi-address smoke (3 words, PHY + model)"
	@echo "  make clean                Remove work/ and logs"
	@echo ""
	@echo "Log header: # BUILD_CONFIG PROJECT=sdram_test_03 RSHIFT=0 CMDREG=1"
