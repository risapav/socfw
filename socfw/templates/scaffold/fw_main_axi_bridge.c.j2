#include "soc_map.h"

static void delay(volatile unsigned count) {
    while (count--) {
        __asm__ volatile ("nop");
    }
}

int main(void) {
    while (1) {
        AXI_GPIO0_BASE[0] = 0x15;
        delay(200000);
        AXI_GPIO0_BASE[0] = 0x2A;
        delay(200000);
    }
    return 0;
}
